generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum PromoLinkType {
  TELEGRAM_BOT
  TELEGRAM_MINI_APP
  PUBLIC_SITE
}

model User {
  id            String              @id @default(cuid())
  avatarUrl     String?
  avatarHash    String?
  email         String              @unique
  passwordHash  String
  username      String?             @unique
  phone         String?
  telegramId    String?             @unique
  promoLinkId   String?
  sourceCode    String?
  sourceType    PromoLinkType?
  role          String              @default("user")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  promoLink     PromoLink?          @relation(fields: [promoLinkId], references: [id], onDelete: SetNull)
  registrations EventRegistration[]
  ratings       Rating[]
  feedback      Feedback[]

  @@index([role])
  @@index([promoLinkId])
  @@index([sourceCode])
  @@index([sourceType])
}

model PromoLink {
  id                 String              @id @default(cuid())
  name               String
  code               String              @unique
  type               PromoLinkType       @default(PUBLIC_SITE)
  targetUrl          String?
  generatedUrl       String?
  clicksCount        Int                 @default(0)
  registrationsCount Int                 @default(0)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  users              User[]
  startSessions      PromoStartSession[]
  clicks             PromoClick[]

  @@index([type])
  @@index([isActive])
  @@index([createdAt])
}

model PromoStartSession {
  id             String        @id @default(cuid())
  telegramUserId String        @unique
  promoCode      String
  promoLinkId    String?
  type           PromoLinkType @default(PUBLIC_SITE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  promoLink      PromoLink?    @relation(fields: [promoLinkId], references: [id], onDelete: SetNull)

  @@index([promoCode])
  @@index([promoLinkId])
  @@index([type])
}

model PromoClick {
  id             String        @id @default(cuid())
  promoLinkId    String
  code           String
  type           PromoLinkType
  telegramUserId String?
  ip             String?
  userAgent      String?
  createdAt      DateTime      @default(now())
  promoLink      PromoLink     @relation(fields: [promoLinkId], references: [id], onDelete: Cascade)

  @@index([promoLinkId])
  @@index([code])
  @@index([type])
  @@index([telegramUserId])
  @@index([createdAt])
}

model Event {
  id                     String              @id @default(cuid())
  imageUrl               String?
  imageHash              String?
  title                  String
  city                   String
  address                String
  features               String
  gameRules              String
  gameType               String
  startsAt               DateTime
  endsAt                 DateTime?
  reminderSentNow        Boolean             @default(false)
  reminderSent24h        Boolean             @default(false)
  reminderSent2h         Boolean             @default(false)
  reminderSent10m        Boolean             @default(false)
  participantLimit       Int
  seatsPerTable          Int                 @default(9)
  pointsForParticipation Int                 @default(10)
  isTemplate             Boolean?            @default(false)
  status                 String              @default("published")
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  registrations          EventRegistration[]

  @@index([gameType, startsAt])
  @@index([status])
}

model EventRegistration {
  id          String    @id @default(cuid())
  userId      String
  eventId     String
  status      String    @default("PARTICIPANT")
  createdAt   DateTime  @default(now())
  cancelledAt DateTime?
  position    Int?
  tableNumber Int?
  seatNumber  Int?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@unique([eventId, tableNumber, seatNumber])
  @@index([eventId, status])
  @@index([userId, status])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  gameType  String
  points    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameType])
  @@index([gameType, points])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  message   String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
}

model ContentPage {
  id        String   @id @default(cuid())
  key       String
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
